# Setup local: cp .secrets/.env.example .secrets/.env
#
# Obrigatório para ler a planilha (local e GitHub Pages):
VITE_SHEETS_API_KEY=sua_chave_de_api_aqui
#
# ID da planilha já está no código (src/config/sheets.ts). Opcional sobrescrever:
# VITE_SHEETS_ID=
# VITE_SHEETS_TAB=
# VITE_SHEETS_WEBAPP_URL=
